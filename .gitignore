.DS_Store

# User media — keep folders (via .gitkeep) but don't commit captures or outputs
src_input/*
!src_input/.gitkeep
src_output/*
!src_output/.gitkeep

# Local test artifacts at repo root
/*.webm
/*.mkv
/*.mp4
/frame_*.png
